---
import { getCollection } from "astro:content"
import PageLayout from "@layouts/PageLayout.astro"
import ArrowCard from "@components/ArrowCard"
import StackCard from "@components/StackCard.astro"
import { SITE, SOCIALS } from "@consts"
import TwinklingStars from "@components/TwinklingStars.astro"
import MeteorShower from "@components/MeteorShower.astro"



const projects = (await getCollection("projects"))
  .filter(project => !project.data.draft)
  .sort((a, b) => (b.data.date?.getTime() || 0) - (a.data.date?.getTime() || 0))
  .slice(0,3)

const stack = [
  { 
    text: "Node.js", 
    icon: "javascript", 
    href: "https://nodejs.org" 
  },
  { 
    text: "TypeScript", 
    icon: "typescript", 
    href: "https://www.typescriptlang.org" 
  },
  { 
    text: "PHP", 
    icon: "php", 
    href: "https://www.php.net/" 
  },
  { 
    text: "Laravel", 
    icon: "laravel", 
    href: "https://laravel.com/" 
  },
  { 
    text: "CodeIgniter", 
    icon: "codeigniter", 
    href: "https://codeigniter.com/" 
  },
  { 
    text: "AWS", 
    icon: "aws", 
    href: "https://aws.amazon.com/" 
  },
  { 
    text: "MySQL", 
    icon: "database", 
    href: "https://www.mysql.com/" 
  },
]
---

<PageLayout title="Home" description={SITE.DESCRIPTION}>

  <!-- Light Mode: Particles -->
  <div class='fixed inset-0 block dark:hidden pointer-events-none z-0'>
    <div id='particles1' class='fixed inset-0'></div>
    <div id='particles2' class='fixed inset-0'></div>
    <div id='particles3' class='fixed inset-0'></div>
  </div>

  <!-- Dark Theme: Stars -->
  <div class='fixed inset-0 bg-black hidden dark:block pointer-events-none z-0'>
    <div id='stars1' class='fixed inset-0'></div>
    <div id='stars2' class='fixed inset-0'></div>
    <div id='stars3' class='fixed inset-0'></div>
  </div>

  <!-- Dark Theme: Twinkling Stars / Metors -->
  <div id="galaxy" class="fixed inset-0 pointer-events-none z-0">
    <div class="hidden dark:block">
      <TwinklingStars/>
      <MeteorShower/>
    </div>
  </div>

  <script is:inline src="/js/bg.js"></script>
  
  <!-- HERO -->
  <section class="relative h-screen w-full flex flex-col items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-neutral-200/50 via-white/80 to-white/90 dark:from-neutral-800/50 dark:via-black/80 dark:to-black/90 z-0"></div>
    
    <div class="relative z-10 w-full max-w-3xl px-6">
      <div class="animate rounded-xl overflow-hidden border border-black/10 dark:border-white/10 shadow-2xl bg-white/50 dark:bg-black/50 backdrop-blur-md">
        <!-- Terminal Header -->
        <div class="flex items-center px-4 py-3 bg-black/5 dark:bg-white/5 border-b border-black/10 dark:border-white/10">
          <div class="flex space-x-2">
            <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
            <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
          </div>
          <div class="mx-auto text-xs font-mono text-black/50 dark:text-white/50">guest@harsh:~</div>
        </div>
        
        <!-- Terminal Body -->
        <div class="p-6 font-mono text-sm md:text-base space-y-4">
          <div class="flex">
            <span class="text-green-600 dark:text-green-400 mr-2">➜</span>
            <span class="text-blue-600 dark:text-blue-400 mr-2">~</span>
            <span class="text-black dark:text-white font-medium">whoami</span>
          </div>
          <div class="text-black/80 dark:text-white/80">
            <p class="text-lg md:text-xl font-bold mb-2">Harsh</p>
            <p class="text-black/60 dark:text-white/60">Backend Developer & Software Engineer</p>
          </div>
          
          <div class="flex pt-4">
            <span class="text-green-600 dark:text-green-400 mr-2">➜</span>
            <span class="text-blue-600 dark:text-blue-400 mr-2">~</span>
            <span class="text-black dark:text-white font-medium">cat skills.json</span>
          </div>
          <div class="text-black/80 dark:text-white/80 pl-4 border-l-2 border-black/10 dark:border-white/10 overflow-x-auto">
            <span class="text-purple-600 dark:text-purple-400">{"{"}</span><br>
            &nbsp;&nbsp;<span class="text-blue-600 dark:text-blue-400">"programming_languages"</span>: [<span class="text-yellow-600 dark:text-yellow-400">"Node.js"</span>, <span class="text-yellow-600 dark:text-yellow-400">"TypeScript"</span>, <span class="text-yellow-600 dark:text-yellow-400">"JavaScript"</span>, <span class="text-yellow-600 dark:text-yellow-400">"PHP"</span>],<br>
            &nbsp;&nbsp;<span class="text-blue-600 dark:text-blue-400">"backend_frameworks"</span>: [<span class="text-yellow-600 dark:text-yellow-400">"Express.js"</span>, <span class="text-yellow-600 dark:text-yellow-400">"Laravel"</span>],<br>
            &nbsp;&nbsp;<span class="text-blue-600 dark:text-blue-400">"databases"</span>: [<span class="text-yellow-600 dark:text-yellow-400">"MySQL"</span>],<br>
            &nbsp;&nbsp;<span class="text-blue-600 dark:text-blue-400">"cloud_and_dev_tools"</span>: [<span class="text-yellow-600 dark:text-yellow-400">"AWS S3"</span>, <span class="text-yellow-600 dark:text-yellow-400">"CloudFront"</span>, <span class="text-yellow-600 dark:text-yellow-400">"Redis"</span>, <span class="text-yellow-600 dark:text-yellow-400">"Firebase"</span>, <span class="text-yellow-600 dark:text-yellow-400">"Git"</span>, <span class="text-yellow-600 dark:text-yellow-400">"GitHub"</span>],<br>
            &nbsp;&nbsp;<span class="text-blue-600 dark:text-blue-400">"security"</span>: [<span class="text-yellow-600 dark:text-yellow-400">"JWT"</span>, <span class="text-yellow-600 dark:text-yellow-400">"Bcrypt"</span>, <span class="text-yellow-600 dark:text-yellow-400">"Joi"</span>]<br>
            <span class="text-purple-600 dark:text-purple-400">{"}"}</span>
          </div>
          
          <div class="flex pt-4 animate-pulse">
            <span class="text-green-600 dark:text-green-400 mr-2">➜</span>
            <span class="text-blue-600 dark:text-blue-400 mr-2">~</span>
            <span class="w-2.5 h-5 bg-black/70 dark:bg-white/70 block"></span>
          </div>
        </div>
      </div>
      
      <div id="ctaButtons" class='animated flex flex-wrap gap-4 justify-center mt-8'>
        <a href='/work' class='py-3 px-6 rounded-lg text-sm md:text-base font-medium bg-black dark:bg-white text-white dark:text-black hover:bg-black/80 hover:dark:bg-white/80 transition-colors shadow-lg'>
          View my work
        </a>
        <a href='/projects' class='py-3 px-6 rounded-lg text-sm md:text-base font-medium border border-black/20 dark:border-white/20 hover:bg-black/5 hover:dark:bg-white/10 transition-colors'>
          Explore projects
        </a>
        <a href='/Harsh Resume (1).pdf' target='_blank' class='py-3 px-6 rounded-lg text-sm md:text-base font-medium border border-black/20 dark:border-white/20 hover:bg-black/5 hover:dark:bg-white/10 transition-colors flex items-center gap-2'>
          <svg class="size-4 fill-current" viewBox="0 0 24 24"><path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/></svg>
          Resume
        </a>
      </div>
    </div>
  </section>

  <div class="relative bg-transparent z-10">
    <div class="mx-auto max-w-screen-xl p-6 lg:p-12 space-y-24 pb-24">
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
        
        <!-- Left Column: About & Tech Stack -->
        <div class="space-y-24">
          <!-- About Section -->
          <section class="animate">
            <h2 class="text-2xl font-bold text-black dark:text-white mb-6">About Me</h2>
            <article class="prose dark:prose-invert max-w-none text-lg">
              <p>I am a <b><i>Backend Developer</i></b> with 1+ years of experience designing and developing scalable web applications.</p>
              <p>I am passionate about writing clean, maintainable code and developing enterprise-level backend solutions. My core expertise lies in Node.js, Express.js, TypeScript, PHP (Laravel), MySQL, Sequelize ORM, Redis, and AWS.</p>
              <p>During my career, I have built secure REST APIs, designed robust database schemas, implemented authentication systems, integrated cloud storage, and optimized performance for high-traffic applications.</p>
              <p>Currently, I work as a Software Engineer (Backend Developer) at Omega Broadcast Pvt. Ltd., where I develop scalable REST APIs and modular backend architectures.</p>
            </article>
          </section>

          <!-- Tech Stack Section -->
          <section class="animate">
            <div class="space-y-6">
              <h2 class="text-2xl font-bold text-black dark:text-white">Core Technologies</h2>
              <div class="flex flex-wrap items-center gap-3">
                {stack.map(item => (
                  <StackCard 
                    text={item.text}
                    icon={item.icon}
                    href={item.href}
                  />
                ))}
              </div>
            </div>
          </section>
        </div>

        <!-- Right Column: Projects & Contact -->
        <div class="space-y-24">
          <!-- Project Preview Section -->
          <section class="animate">
            <div class="space-y-6">
              <div class="flex justify-between items-end border-b border-black/10 dark:border-white/10 pb-4">
                <h2 class="text-2xl font-bold text-black dark:text-white">
                  Recent projects
                </h2>
                <a href="/projects" class="group flex gap-1 items-center underline decoration-[.5px] decoration-black/25 dark:decoration-white/50 hover:decoration-black dark:hover:decoration-white text-black dark:text-white underline-offset-2 blend">
                  <span class="text-black/75 dark:text-white/75 group-hover:text-black group-hover:dark:text-white blend">
                    All projects
                  </span>
                </a>
              </div>
              <ul class="space-y-6">
                {projects.map((project) => (
                  <li class="bg-black/5 dark:bg-white/5 rounded-xl p-4 transition-transform hover:-translate-y-1">
                    <ArrowCard entry={project} />
                  </li>
                ))}
              </ul>
            </div>
          </section>

          <!-- Contact Section -->
          <section class="animate">
            <div class="bg-black/5 dark:bg-white/5 p-8 rounded-2xl border border-black/10 dark:border-white/10">
              <h2 class="text-2xl font-bold text-black dark:text-white mb-4">
                Let's Connect
              </h2>
              <p class="mb-6 text-lg">
                Reach out to me via email or on social media. I'm always open to discussing new projects, creative ideas, or opportunities to be part of your visions.
              </p>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {SOCIALS.map(social => (
                  <a href={social.HREF} target="_blank" class="flex items-center gap-3 p-3 rounded-lg hover:bg-black/10 dark:hover:bg-white/10 transition-colors">
                    <div class="w-10 h-10 flex items-center justify-center rounded-full bg-black/10 dark:bg-white/10 text-black dark:text-white">
                      <svg class="size-5 fill-current">
                        <use href={`/social.svg#${social.ICON}`}></use>
                      </svg>
                    </div>
                    <div class="flex flex-col">
                      <span class="font-semibold text-black dark:text-white">{social.NAME}</span>
                      <span class="text-sm opacity-75 truncate max-w-[150px]">{social.TEXT}</span>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          </section>
        </div>

      </div>
    </div>
  </div>
</PageLayout>
